# Database connection (RDS Proxy in production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=postgres

# Connection pool configuration
# DB_POOL_MAX=5 is intentional: each Lambda instance holds 5 connections.
# With 50 concurrent Lambda instances = 250 connections.
# RDS Proxy multiplexes these onto far fewer actual RDS connections.
DB_POOL_MAX=5

# Node environment
NODE_ENV=development

# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
